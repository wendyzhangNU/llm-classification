    "subsample": 0.8618137090358877,
    "rsm": 0.9335879435891674,
    "min_data_in_leaf": 5,
    "random_seed": SEED,
    "verbose": 0,
    "allow_writing_files": False,
    "thread_count": -1,
    "use_best_model": False,
}

# Ensemble weights
# Previous attempt at OOF-optimized weights: W_XGB=0.3974, W_LGB=0.2255, W_CAT=0.3771
W_XGB = 0.6117
W_LGB = 0.2309
W_CAT = 0.1575

# Train full + predict
def smooth_probs(p, eps=1e-12):
    p = np.asarray(p, dtype=np.float64)
    p = np.clip(p, eps, 1.0)
    p = p / p.sum(axis=1, keepdims=True)
    return p.astype(np.float32)

print("Fitting XGBoost on full data...")
xgb = XGBClassifier(**XGB_PARAMS)
xgb.fit(X, y)
p_xgb = smooth_probs(xgb.predict_proba(X_test))

print("Fitting LightGBM on full data...")
lgbm = LGBMClassifier(**LGB_PARAMS)
lgbm.fit(X, y)
p_lgb = smooth_probs(lgbm.predict_proba(X_test))

print("Fitting CatBoost on full data...")
cat = CatBoostClassifier(**CAT_PARAMS)
cat.fit(X, y)
p_cat = smooth_probs(cat.predict_proba(X_test))

# Ensemble + submission
p_ens = W_XGB * p_xgb + W_LGB * p_lgb + W_CAT * p_cat
p_ens = smooth_probs(p_ens)

submission = pd.DataFrame({
    "id": test["id"].values,
    "winner_model_a": p_ens[:, class_to_idx.get("A", 0)],
    "winner_model_b": p_ens[:, class_to_idx.get("B", 1)],
    "winner_tie":     p_ens[:, class_to_idx.get("Tie", 2)],
})

