def parse_response(resp):
    """Space-join: cleaner than newline-join, doesn't inflate char counts"""
    try:
        parsed = json.loads(resp)
        if isinstance(parsed, list):
            return ' '.join([str(t) for t in parsed])
        return str(parsed)
    except:
        return str(resp)

for df in [train, test]:
