# TF-IDF + SVD diffs
print("Fitting TF-IDF + SVD...")
all_text = pd.concat([train["response_a"], train["response_b"], test["response_a"], test["response_b"]]).astype(str)

tfidf = TfidfVectorizer(max_features=10000, stop_words="english")
tfidf.fit(all_text)

svd = TruncatedSVD(n_components=50, random_state=42)
svd.fit(tfidf.transform(all_text))
svd_cols = [f"svd_diff_{i}" for i in range(50)]

diff_train = svd.transform(tfidf.transform(train["response_b"].astype(str))) - svd.transform(
    tfidf.transform(train["response_a"].astype(str))
)
diff_test = svd.transform(tfidf.transform(test["response_b"].astype(str))) - svd.transform(
    tfidf.transform(test["response_a"].astype(str))
)

train = pd.concat([train, pd.DataFrame(diff_train, columns=svd_cols, index=train.index)], axis=1)
test = pd.concat([test, pd.DataFrame(diff_test, columns=svd_cols, index=test.index)], axis=1)

print("Fitting bigram TF-IDF + SVD...")
tfidf_bi = TfidfVectorizer(max_features=5000, ngram_range=(2, 2), stop_words="english")
tfidf_bi.fit(all_text)

svd_bi = TruncatedSVD(n_components=25, random_state=42)
svd_bi.fit(tfidf_bi.transform(all_text))
bi_cols = [f"bigram_diff_{i}" for i in range(25)]

diff_train_bi = svd_bi.transform(tfidf_bi.transform(train["response_b"].astype(str))) - svd_bi.transform(
    tfidf_bi.transform(train["response_a"].astype(str))
)
diff_test_bi = svd_bi.transform(tfidf_bi.transform(test["response_b"].astype(str))) - svd_bi.transform(
    tfidf_bi.transform(test["response_a"].astype(str))
)

train = pd.concat([train, pd.DataFrame(diff_train_bi, columns=bi_cols, index=train.index)], axis=1)
test = pd.concat([test, pd.DataFrame(diff_test_bi, columns=bi_cols, index=test.index)], axis=1)

print("Computing prompt-response cosine similarities...")
tfidf_full = TfidfVectorizer(max_features=30000, ngram_range=(1, 2), min_df=3, dtype=np.float32)
tfidf_full.fit(
    pd.concat(
        [
            train["prompt"],
            train["response_a"],
            train["response_b"],
            test["prompt"],
            test["response_a"],
            test["response_b"],
        ]
    ).astype(str)
)

P_train = sk_normalize(tfidf_full.transform(train["prompt"].astype(str)))
A_train = sk_normalize(tfidf_full.transform(train["response_a"].astype(str)))
B_train = sk_normalize(tfidf_full.transform(train["response_b"].astype(str)))

P_test = sk_normalize(tfidf_full.transform(test["prompt"].astype(str)))
A_test = sk_normalize(tfidf_full.transform(test["response_a"].astype(str)))
B_test = sk_normalize(tfidf_full.transform(test["response_b"].astype(str)))

train["tf_sim_a"] = np.asarray(P_train.multiply(A_train).sum(axis=1)).reshape(-1)
train["tf_sim_b"] = np.asarray(P_train.multiply(B_train).sum(axis=1)).reshape(-1)
train["tf_sim_diff"] = train["tf_sim_b"] - train["tf_sim_a"]

test["tf_sim_a"] = np.asarray(P_test.multiply(A_test).sum(axis=1)).reshape(-1)
test["tf_sim_b"] = np.asarray(P_test.multiply(B_test).sum(axis=1)).reshape(-1)
test["tf_sim_diff"] = test["tf_sim_b"] - test["tf_sim_a"]

print("Computing response A-B similarity (vectorized)...")
ta_train = sk_normalize(tfidf.transform(train["response_a"].astype(str)))
tb_train = sk_normalize(tfidf.transform(train["response_b"].astype(str)))
train["resp_similarity"] = np.asarray(ta_train.multiply(tb_train).sum(axis=1)).reshape(-1)

ta_test = sk_normalize(tfidf.transform(test["response_a"].astype(str)))
tb_test = sk_normalize(tfidf.transform(test["response_b"].astype(str)))
test["resp_similarity"] = np.asarray(ta_test.multiply(tb_test).sum(axis=1)).reshape(-1)

