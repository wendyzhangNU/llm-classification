P = np.stack([oof_xgb_q, oof_lgb_q, oof_cat_q], axis=0)  # (M, Nsub, C)

def ens_loss(w):
    w = np.clip(w, 0, 1)
    w = w / (w.sum() + 1e-12)
    blended = np.tensordot(w, P, axes=(0, 0))  # (Nsub, C)
    return log_loss(y_sub, blended)

x0 = np.ones(len(model_names)) / len(model_names)
cons = ({"type": "eq", "fun": lambda w: np.sum(w) - 1.0},)
bounds = [(0.0, 1.0)] * len(model_names)
res = minimize(ens_loss, x0, method="SLSQP", bounds=bounds, constraints=cons, options={"maxiter": 200})

w_opt = np.clip(res.x, 0, 1)
w_opt = w_opt / (w_opt.sum() + 1e-12)

print("\nBest OOF weights (SUBSAMPLE):")
for n, w_ in zip(model_names, w_opt):
    print(f"  {n:>8}: {w_:.4f}")
