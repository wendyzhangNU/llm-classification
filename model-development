# Fig 2: Feature Importance
def plot_feature_importance(final_model, feature_cols, top_n=20,
                             save_path="/content/fig2_feature_importance.png"):
    booster = final_model.get_booster()
    score = booster.get_score(importance_type='gain')  # keys like "f0", "f1", ...
    importances = np.zeros(len(feature_cols), dtype=float)
    for k, v in score.items():
        idx = int(k[1:])  # "f12" -> 12
        if 0 <= idx < len(importances):
            importances[idx] = v

    feat_imp = pd.Series(importances, index=feature_cols).sort_values(ascending=False)
    top = feat_imp.head(top_n).sort_values(ascending=True)

    fig, ax = plt.subplots(figsize=(8, 7))
    bars = ax.barh(top.index, top.values,
                   color="#8E44AD", edgecolor='white', linewidth=0.5, height=0.65)

    max_val = top.values.max() if len(top) else 1.0
    for bar in bars:
        w = bar.get_width()
        ax.text(w + max_val * 0.01, bar.get_y() + bar.get_height() / 2,
                f'{w:,.2f}', va='center', ha='left', fontsize=8.5)

    ax.set_xlabel('Feature Importance (Gain)', labelpad=8)
    ax.set_xlim(0, max_val * 1.15)
    ax.set_title(f'Fig. 2 — Top {top_n} Feature Importances by Gain\n'
                 '(XGBoost, trained on engineered features)',
                 fontsize=11, pad=12)
    plt.tight_layout()
    plt.savefig(save_path)
    plt.close()
    print(f"Saved → {save_path}")

# Fig 3: Confusion Matrix
def plot_confusion_matrix(model, X_valid, y_valid, le,
                           save_path="/content/fig3_confusion_matrix.png"):
    y_pred = model.predict(X_valid)
    cm = confusion_matrix(y_valid, y_pred)
    cm_norm = cm.astype(float) / cm.sum(axis=1, keepdims=True)
    class_names = le.classes_
    n = len(class_names)

    fig, axes = plt.subplots(1, 2, figsize=(11, 4.5),
                              gridspec_kw={'width_ratios': [1, 1], 'wspace': 0.35})
    for ax, data, title, fmt in zip(
        axes,
        [cm, cm_norm],
        ['(a) Raw Counts', '(b) Row-Normalized (Recall per Class)'],
        [lambda v: f'{v:,}', lambda v: f'{v:.2f}']
    ):
        im = ax.imshow(data, interpolation='nearest', cmap='Blues',
                       vmin=0, vmax=(None if data is cm else 1))
        ax.set_title(title, fontsize=11, pad=10)
        plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
        thresh = data.max() * 0.6
        for i in range(n):
            for j in range(n):
                ax.text(j, i, fmt(data[i, j]), ha='center', va='center',
                        fontsize=11, color='white' if data[i, j] > thresh else 'black')
        ax.set_xticks(range(n)); ax.set_yticks(range(n))
        ax.set_xticklabels([f'Pred {c}' for c in class_names])
        ax.set_yticklabels([f'True {c}' for c in class_names])
        ax.set_xlabel('Predicted Label', labelpad=8)
        ax.set_ylabel('True Label', labelpad=8)

    fig.suptitle('Fig. 3 — Confusion Matrix on Held-Out Validation Set\n'
                 f'(n = {len(y_valid):,}  |  XGBoost tuned params)',
                 fontsize=11, y=1.02)
    plt.tight_layout()
    plt.savefig(save_path)
    plt.close()
    print(f"Saved → {save_path}")

