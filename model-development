# Feature engineering
def engineer_all(df):
    df = df.copy()
    for col in ("prompt", "response_a", "response_b"):
        df[col] = df[col].fillna("").astype(str)

    df["prompt_len"] = df["prompt"].str.len()
    df["resp_a_len"] = df["response_a"].str.len()
    df["resp_b_len"] = df["response_b"].str.len()
    df["len_diff"] = df["resp_b_len"] - df["resp_a_len"]

    df["prompt_word_count"] = df["prompt"].str.split().str.len()
    df["resp_a_word_count"] = df["response_a"].str.split().str.len()
    df["resp_b_word_count"] = df["response_b"].str.split().str.len()
    df["word_count_diff"] = df["resp_b_word_count"] - df["resp_a_word_count"]

    df["resp_a_len_ratio"] = df["resp_a_word_count"] / (df["prompt_word_count"] + 1)
    df["resp_b_len_ratio"] = df["resp_b_word_count"] / (df["prompt_word_count"] + 1)
    df["len_ratio_diff"] = df["resp_b_len_ratio"] - df["resp_a_len_ratio"]
    df["len_ratio"] = df["resp_b_len"] / (df["resp_a_len"] + 1)
    df["word_ratio"] = df["resp_b_word_count"] / (df["resp_a_word_count"] + 1)

    df["resp_a_bold"] = df["response_a"].str.count(r"\*\*")
    df["resp_b_bold"] = df["response_b"].str.count(r"\*\*")
    df["bold_diff"] = df["resp_b_bold"] - df["resp_a_bold"]

    df["resp_a_hash"] = df["response_a"].str.count(r"##")
    df["resp_b_hash"] = df["response_b"].str.count(r"##")
    df["hash_diff"] = df["resp_b_hash"] - df["resp_a_hash"]

    df["resp_a_new_line"] = df["response_a"].str.count(r"\n")
    df["resp_b_new_line"] = df["response_b"].str.count(r"\n")
    df["new_line_diff"] = df["resp_b_new_line"] - df["resp_a_new_line"]

    df["resp_a_code"] = df["response_a"].str.count(r"`")
    df["resp_b_code"] = df["response_b"].str.count(r"`")
    df["code_diff"] = df["resp_b_code"] - df["resp_a_code"]

    df["resp_a_list"] = df["response_a"].str.count(r"(?m)^\s*(?:\d+\.|\-|\*|\+)\s+")
    df["resp_b_list"] = df["response_b"].str.count(r"(?m)^\s*(?:\d+\.|\-|\*|\+)\s+")
    df["list_diff"] = df["resp_b_list"] - df["resp_a_list"]

    df["resp_a_excl"] = df["response_a"].str.count(r"!")
    df["resp_b_excl"] = df["response_b"].str.count(r"!")
    df["excl_diff"] = df["resp_b_excl"] - df["resp_a_excl"]

    df["resp_a_question"] = df["response_a"].str.count(r"\?")
    df["resp_b_question"] = df["response_b"].str.count(r"\?")
    df["question_diff"] = df["resp_b_question"] - df["resp_a_question"]

    df["resp_a_quote"] = df["response_a"].str.count(r'"')
    df["resp_b_quote"] = df["response_b"].str.count(r'"')
    df["quote_diff"] = df["resp_b_quote"] - df["resp_a_quote"]

    df["resp_a_sentences"] = df["response_a"].str.count(r"[.!?]")
    df["resp_b_sentences"] = df["response_b"].str.count(r"[.!?]")
    df["sentence_diff"] = df["resp_b_sentences"] - df["resp_a_sentences"]
    df["sentence_ratio"] = df["resp_b_sentences"] / (df["resp_a_sentences"] + 1)

    stats_a = df["response_a"].apply(sentence_stats)
    stats_b = df["response_b"].apply(sentence_stats)

    df["resp_a_sent_count"] = stats_a.apply(lambda x: x[0])
    df["resp_a_avg_sent_len"] = stats_a.apply(lambda x: x[1])
    df["resp_a_sent_var"] = stats_a.apply(lambda x: x[2])

    df["resp_b_sent_count"] = stats_b.apply(lambda x: x[0])
    df["resp_b_avg_sent_len"] = stats_b.apply(lambda x: x[1])
    df["resp_b_sent_var"] = stats_b.apply(lambda x: x[2])

    df["sent_count_diff"] = df["resp_b_sent_count"] - df["resp_a_sent_count"]
    df["avg_sent_len_diff"] = df["resp_b_avg_sent_len"] - df["resp_a_avg_sent_len"]
    df["sent_var_diff"] = df["resp_b_sent_var"] - df["resp_a_sent_var"]

    df["resp_a_overlap"] = df.apply(lambda r: keyword_overlap(r["prompt"], r["response_a"]), axis=1)
    df["resp_b_overlap"] = df.apply(lambda r: keyword_overlap(r["prompt"], r["response_b"]), axis=1)
    df["overlap_diff"] = df["resp_b_overlap"] - df["resp_a_overlap"]
    df["overlap_ratio"] = df["resp_b_overlap"] / (df["resp_a_overlap"] + 0.001)

    df["resp_a_confidence"] = df["response_a"].str.count(CONFIDENCE_RE, flags=re.I)
    df["resp_b_confidence"] = df["response_b"].str.count(CONFIDENCE_RE, flags=re.I)
    df["confidence_diff"] = df["resp_b_confidence"] - df["resp_a_confidence"]

    df["resp_a_is_ai"] = df["response_a"].str.lower().str.count(r"an ai")
    df["resp_b_is_ai"] = df["response_b"].str.lower().str.count(r"an ai")
    df["ai_diff"] = df["resp_b_is_ai"] - df["resp_a_is_ai"]

    # Language match
    df["a_lang_match"] = (df["prompt_lang"] == df["resp_a_lang"]).astype(int) if "prompt_lang" in df.columns else 0
    df["b_lang_match"] = (df["prompt_lang"] == df["resp_b_lang"]).astype(int) if "prompt_lang" in df.columns else 0
    df["lang_match_diff"] = df["b_lang_match"] - df["a_lang_match"]
    df["is_prompt_en"] = (df["prompt_lang"] == "en").astype(int) if "prompt_lang" in df.columns else 0

    df["resp_a_lexdiv"] = df["response_a"].apply(lexical_diversity)
    df["resp_b_lexdiv"] = df["response_b"].apply(lexical_diversity)
    df["lexdiv_diff"] = df["resp_b_lexdiv"] - df["resp_a_lexdiv"]

    df["resp_a_vocab_rich"] = df["response_a"].apply(vocab_richness)
    df["resp_b_vocab_rich"] = df["response_b"].apply(vocab_richness)
    df["vocab_rich_diff"] = df["resp_b_vocab_rich"] - df["resp_a_vocab_rich"]

    df["resp_a_hedge"] = df["response_a"].apply(lambda t: count_lexicon(t, HEDGE_LEXICON))
    df["resp_b_hedge"] = df["response_b"].apply(lambda t: count_lexicon(t, HEDGE_LEXICON))
    df["hedge_diff"] = df["resp_b_hedge"] - df["resp_a_hedge"]

    df["resp_a_polite"] = df["response_a"].apply(lambda t: count_lexicon(t, POLITENESS_LEXICON))
    df["resp_b_polite"] = df["response_b"].apply(lambda t: count_lexicon(t, POLITENESS_LEXICON))
    df["polite_diff"] = df["resp_b_polite"] - df["resp_a_polite"]

    df["resp_a_refusal"] = df["response_a"].apply(refusal_score)
    df["resp_b_refusal"] = df["response_b"].apply(refusal_score)
    df["refusal_diff"] = df["resp_b_refusal"] - df["resp_a_refusal"]
    df["resp_a_has_refusal"] = (df["resp_a_refusal"] > 0).astype(int)
    df["resp_b_has_refusal"] = (df["resp_b_refusal"] > 0).astype(int)
    df["has_refusal_diff"] = df["resp_b_has_refusal"] - df["resp_a_has_refusal"]

    # Readability
    df["resp_a_readability"] = df["response_a"].apply(readability_score)
    df["resp_b_readability"] = df["response_b"].apply(readability_score)
    df["readability_diff"] = df["resp_b_readability"] - df["resp_a_readability"]

    # TextBlob + VADER
    df["resp_a_sentiment"] = df["response_a"].apply(lambda x: TextBlob(x).sentiment.polarity)
    df["resp_b_sentiment"] = df["response_b"].apply(lambda x: TextBlob(x).sentiment.polarity)
    df["sentiment_diff"] = df["resp_b_sentiment"] - df["resp_a_sentiment"]

    prompt_v = df["prompt"].apply(analyzer.polarity_scores)
    resp_a_v = df["response_a"].apply(analyzer.polarity_scores)
    resp_b_v = df["response_b"].apply(analyzer.polarity_scores)

    for key in ("neg", "neu", "pos", "compound"):
        df[f"prompt_{key}"] = prompt_v.apply(lambda x: x[key])
        df[f"resp_a_{key}"] = resp_a_v.apply(lambda x: x[key])
        df[f"resp_b_{key}"] = resp_b_v.apply(lambda x: x[key])
        df[f"{key}_diff"] = df[f"resp_b_{key}"] - df[f"resp_a_{key}"]

    df["prompt_punct_count"] = df["prompt"].str.count(r"[.,;:!?\-]")
    df["prompt_punct_per_word"] = df["prompt_punct_count"] / (df["prompt_word_count"] + 1)
    df["prompt_has_question"] = df["prompt"].str.contains(r"\?").astype(int)

    df["len_x_overlap"] = df["len_ratio"] * df["overlap_ratio"]
    df["len_x_compound"] = df["len_ratio"] * (df["resp_b_compound"] / (df["resp_a_compound"].abs() + 0.001))

    return df


