A_test = sk_normalize(tfidf_full.transform(test["response_a"].astype(str)))
B_test = sk_normalize(tfidf_full.transform(test["response_b"].astype(str)))

train["tf_sim_a"] = np.asarray(P_train.multiply(A_train).sum(axis=1)).reshape(-1)
train["tf_sim_b"] = np.asarray(P_train.multiply(B_train).sum(axis=1)).reshape(-1)
train["tf_sim_diff"] = train["tf_sim_b"] - train["tf_sim_a"]

test["tf_sim_a"] = np.asarray(P_test.multiply(A_test).sum(axis=1)).reshape(-1)
test["tf_sim_b"] = np.asarray(P_test.multiply(B_test).sum(axis=1)).reshape(-1)
test["tf_sim_diff"] = test["tf_sim_b"] - test["tf_sim_a"]

print("Computing response A-B similarity...")
ta_train = tfidf.transform(train["response_a"].astype(str))
tb_train = tfidf.transform(train["response_b"].astype(str))
train["resp_similarity"] = np.array([cos_sim(a, b)[0][0] for a, b in zip(ta_train, tb_train)])

ta_test = tfidf.transform(test["response_a"].astype(str))
tb_test = tfidf.transform(test["response_b"].astype(str))
test["resp_similarity"] = np.array([cos_sim(a, b)[0][0] for a, b in zip(ta_test, tb_test)])

