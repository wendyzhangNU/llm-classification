def cv_oof_xgb(params, X_, y_, skf_, early_stopping_rounds=40):
    oof = np.zeros((X_.shape[0], N_CLASSES), dtype=np.float32)
    fold_logs = []
    best_iters = []

    for fold, (tr_idx, va_idx) in enumerate(skf_.split(X_, y_), 1):
        X_tr, X_va = X_[tr_idx], X_[va_idx]
        y_tr, y_va = y_[tr_idx], y_[va_idx]

        m = XGBClassifier(**params, early_stopping_rounds=early_stopping_rounds)
        m.fit(X_tr, y_tr, eval_set=[(X_va, y_va)], verbose=False)

        probs = m.predict_proba(X_va)
        oof[va_idx] = probs
        fold_ll = log_loss(y_va, probs)
        fold_logs.append(fold_ll)

        bi = getattr(m, "best_iteration", None)
        best_iters.append(int(bi + 1) if bi is not None else int(params["n_estimators"]))

    overall = log_loss(y_, oof)
    return oof, overall, fold_logs, best_iters

def cv_oof_lgb(params, X_, y_, skf_, early_stopping_rounds=60):
    import lightgbm as lgb
    oof = np.zeros((X_.shape[0], N_CLASSES), dtype=np.float32)
    fold_logs = []
    best_iters = []

    for fold, (tr_idx, va_idx) in enumerate(skf_.split(X_, y_), 1):
        X_tr, X_va = X_[tr_idx], X_[va_idx]
        y_tr, y_va = y_[tr_idx], y_[va_idx]

        m = LGBMClassifier(**params)
        m.fit(
            X_tr, y_tr,
            eval_set=[(X_va, y_va)],
            eval_metric="multi_logloss",
            callbacks=[lgb.early_stopping(early_stopping_rounds, verbose=False)],
        )

        probs = m.predict_proba(X_va)
        oof[va_idx] = probs
        fold_ll = log_loss(y_va, probs)
        fold_logs.append(fold_ll)

        bi = getattr(m, "best_iteration_", None)
        best_iters.append(int(bi) if bi is not None else int(params["n_estimators"]))

    overall = log_loss(y_, oof)
    return oof, overall, fold_logs, best_iters

def cv_oof_cat(params, X_, y_, skf_):
    # Hard assert
    assert params.get("bootstrap_type") != "Bayesian", params

    oof = np.zeros((X_.shape[0], N_CLASSES), dtype=np.float32)
    fold_logs = []
    best_iters = []

    for fold, (tr_idx, va_idx) in enumerate(skf_.split(X_, y_), 1):
        X_tr, X_va = X_[tr_idx], X_[va_idx]
        y_tr, y_va = y_[tr_idx], y_[va_idx]

        m = CatBoostClassifier(**params)
        m.fit(X_tr, y_tr, eval_set=(X_va, y_va))

        probs = m.predict_proba(X_va)
        oof[va_idx] = probs
        fold_ll = log_loss(y_va, probs)
        fold_logs.append(fold_ll)

        bi = None
        if hasattr(m, "get_best_iteration"):
            try:
                bi = m.get_best_iteration()
            except Exception:
                bi = None
        best_iters.append(int(bi) if (bi is not None and bi > 0) else int(params["iterations"]))

    overall = log_loss(y_, oof)
    return oof, overall, fold_logs, best_iters

def randomized_search_xgb(X_, y_, skf_, n_trials=6):
    best_params, best_oof, best_score, best_bestiters = None, None, float("inf"), None
    for t in range(1, n_trials + 1):
        params = sample_xgb_params_quick()
        oof, overall, fold_logs, best_iters = cv_oof_xgb(params, X_, y_, skf_)
        print(
            f"[XGBoost] Trial {t}/{n_trials} OOF={overall:.6f} "
            f"folds={[round(x,6) for x in fold_logs]} best_iters={int(np.median(best_iters))}"
        )
        if overall < best_score:
            best_score, best_params, best_oof, best_bestiters = overall, params, oof.copy(), best_iters
    best_n_estimators = int(np.median(best_bestiters)) if best_bestiters is not None else best_params["n_estimators"]
    best_params_full = dict(best_params)
    best_params_full["n_estimators"] = best_n_estimators
    print(f"--> Best XGBoost OOF={best_score:.6f}, refit n_estimators={best_n_estimators}\nparams={best_params_full}\n")
    return best_params_full, best_oof, best_score

def randomized_search_lgb(X_, y_, skf_, n_trials=6):
    best_params, best_oof, best_score, best_bestiters = None, None, float("inf"), None
    for t in range(1, n_trials + 1):
        params = sample_lgb_params_quick()
        oof, overall, fold_logs, best_iters = cv_oof_lgb(params, X_, y_, skf_)
        print(
            f"[LightGBM] Trial {t}/{n_trials} OOF={overall:.6f} "
            f"folds={[round(x,6) for x in fold_logs]} best_iters={int(np.median(best_iters))}"
        )
        if overall < best_score:
            best_score, best_params, best_oof, best_bestiters = overall, params, oof.copy(), best_iters
    best_n_estimators = int(np.median(best_bestiters)) if best_bestiters is not None else best_params["n_estimators"]
    best_params_full = dict(best_params)
    best_params_full["n_estimators"] = best_n_estimators
    print(f"--> Best LightGBM OOF={best_score:.6f}, refit n_estimators={best_n_estimators}\nparams={best_params_full}\n")
    return best_params_full, best_oof, best_score

def randomized_search_cat(X_, y_, skf_, n_trials=6):
    best_params, best_oof, best_score, best_bestiters = None, None, float("inf"), None
    for t in range(1, n_trials + 1):
        params = sample_cat_params_quick()
        assert params.get("bootstrap_type") != "Bayesian", params

        oof, overall, fold_logs, best_iters = cv_oof_cat(params, X_, y_, skf_)
