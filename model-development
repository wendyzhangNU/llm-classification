_word_re = re.compile(r"[A-Za-z']+")

def tokenize(text):
    if not isinstance(text, str): return []
    return _word_re.findall(text.lower())

def lexical_diversity(text):
    toks = tokenize(text)
    return len(set(toks)) / len(toks) if toks else 0.0

def count_lexicon(text, lexicon):
    s = set(lexicon)
    return sum(1 for t in tokenize(text) if t in s)

def vocab_richness(text):
    words = str(text).lower().split()
    return len(set(words)) / len(words) if words else 0

def keyword_overlap(prompt, response):
    p = set(str(prompt).lower().split())
    r = set(str(response).lower().split())
    return len(p & r) / len(p) if p else 0

def refusal_score(text):
    text = str(text).lower()
    score = 0
    for phrase in ["i cannot", "i can't", "i am not able", "i'm not able",
                   "i'm unable", "i am unable", "can't satisfy your request",
                   "cannot satisfy your request", "i must decline",
                   "i'm not going to", "i can not"]:
        score += text.count(phrase) * 3
    for phrase in ["i'm sorry", "i am sorry", "i apologize", "my apologies",
                   "sorry,", "sorry.", "unfortunately"]:
        score += text.count(phrase) * 2
    for phrase in ["sorry", "apologize", "apologies", "regret"]:
        score += text.count(phrase) * 1
    return score

def sentence_stats(text):
    sentences = re.split(r'[.!?]+', str(text))
    sentences = [s.strip() for s in sentences if s.strip()]
    if not sentences:
        return 0, 0.0, 0.0
    lengths = [len(s.split()) for s in sentences]
    return len(sentences), np.mean(lengths), (np.std(lengths) if len(lengths) > 1 else 0.0)

