# Prompt-Response cosine similarity
print("Computing prompt-response cosine similarities...")
tfidf_full = TfidfVectorizer(max_features=30000, ngram_range=(1,2), min_df=3, dtype=np.float32)
tfidf_full.fit(pd.concat([
    train['prompt'], train['response_a'], train['response_b'],
    test['prompt'],  test['response_a'],  test['response_b']
]).astype(str))

from sklearn.preprocessing import normalize as sk_normalize

for label, df in [("train", train), ("test", test)]:
    P = sk_normalize(tfidf_full.transform(df['prompt'].astype(str)))
    A = sk_normalize(tfidf_full.transform(df['response_a'].astype(str)))
    B = sk_normalize(tfidf_full.transform(df['response_b'].astype(str)))

    df['tf_sim_a']    = np.asarray(P.multiply(A).sum(axis=1)).reshape(-1)
    df['tf_sim_b']    = np.asarray(P.multiply(B).sum(axis=1)).reshape(-1)
    df['tf_sim_diff'] = df['tf_sim_b'] - df['tf_sim_a']

# Response similarity (A vs B)
print("Computing response A-B similarity...")
for label, df in [("train", train), ("test", test)]:
    ta = tfidf.transform(df['response_a'].astype(str))
    tb = tfidf.transform(df['response_b'].astype(str))
    df['resp_similarity'] = np.array([cos_sim(a, b)[0][0] for a, b in zip(ta, tb)])

