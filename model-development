            f"folds={[round(x,6) for x in fold_logs]} best_iters={int(np.median(best_iters))} "
            f"bootstrap={params.get('bootstrap_type')}"
        )
        if overall < best_score:
            best_score, best_params, best_oof, best_bestiters = overall, params, oof.copy(), best_iters

    best_iterations = int(np.median(best_bestiters)) if best_bestiters is not None else best_params["iterations"]
    best_params_full = dict(best_params)
    best_params_full["iterations"] = best_iterations
    print(f"--> Best CatBoost OOF={best_score:.6f}, refit iterations={best_iterations}\nparams={best_params_full}\n")
    return best_params_full, best_oof, best_score

