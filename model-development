# Run searches
t0 = time.time()
best_xgb_params, oof_xgb, ll_xgb = randomized_search_xgb(X, y, skf, n_trials=N_TRIALS["XGBoost"])
best_lgb_params, oof_lgb, ll_lgb = randomized_search_lgb(X, y, skf, n_trials=N_TRIALS["LightGBM"])
best_cat_params, oof_cat, ll_cat = randomized_search_cat(X, y, skf, n_trials=N_TRIALS["CatBoost"])
print(f"Search done in {(time.time()-t0)/60:.2f} min")

# Optimize ensemble weights on OOF
model_names = ["XGBoost", "LightGBM", "CatBoost"]
oof_probs = {"XGBoost": oof_xgb, "LightGBM": oof_lgb, "CatBoost": oof_cat}
P = np.stack([oof_probs[n] for n in model_names], axis=0)  # (M, N, C)

def ens_loss(w):
    w = np.clip(w, 0, 1)
    w = w / (w.sum() + 1e-12)
    blended = np.tensordot(w, P, axes=(0, 0))  # (N, C)
    return log_loss(y, blended)

x0 = np.ones(len(model_names)) / len(model_names)
cons = ({"type": "eq", "fun": lambda w: np.sum(w) - 1.0},)
bounds = [(0.0, 1.0)] * len(model_names)
res = minimize(ens_loss, x0, method="SLSQP", bounds=bounds, constraints=cons, options={"maxiter": 200})
w_opt = np.clip(res.x, 0, 1)
w_opt = w_opt / (w_opt.sum() + 1e-12)

print("\nBest OOF weights:")
for n, w_ in zip(model_names, w_opt):
    print(f"  {n:>8}: {w_:.4f}")
print(f"Best OOF ensemble logloss: {ens_loss(w_opt):.6f}")

# Full-train retrain with early stopping for XGB/LGB/CB
X_tr_full, X_va_full, y_tr_full, y_va_full = train_test_split(
    X, y, test_size=0.15, stratify=y, random_state=SEED
)

xgb_full_params = dict(best_xgb_params)
xgb_full_params["n_estimators"] = max(int(best_xgb_params.get("n_estimators", 2000)), 2000)
xgb_full = XGBClassifier(**xgb_full_params, early_stopping_rounds=150)
xgb_full.fit(X_tr_full, y_tr_full, eval_set=[(X_va_full, y_va_full)], verbose=False)
p_test_xgb = xgb_full.predict_proba(X_test)

lgb_full_params = dict(best_lgb_params)
lgb_full_params["n_estimators"] = max(int(best_lgb_params.get("n_estimators", 5000)), 5000)
lgb_full = LGBMClassifier(**lgb_full_params)
lgb_full.fit(
    X_tr_full, y_tr_full,
    eval_set=[(X_va_full, y_va_full)],
    eval_metric="multi_logloss",
    callbacks=[__import__("lightgbm").early_stopping(300, verbose=False)],
)
p_test_lgb = lgb_full.predict_proba(X_test)

cat_full_params = dict(best_cat_params)
cat_full_params["iterations"] = max(int(best_cat_params.get("iterations", 3000)), 3000)
cat_full_params.update(
    {
        "use_best_model": True,
        "od_type": "Iter",
        "od_wait": 300,
        "eval_metric": "MultiClass",
        "verbose": 0,
    }
)
cat_full = CatBoostClassifier(**cat_full_params)
cat_full.fit(X_tr_full, y_tr_full, eval_set=(X_va_full, y_va_full))
p_test_cat = cat_full.predict_proba(X_test)

p_test_ens = w_opt[0] * p_test_xgb + w_opt[1] * p_test_lgb + w_opt[2] * p_test_cat
p_test_ens = np.clip(p_test_ens, 1e-12, 1.0)
p_test_ens = p_test_ens / p_test_ens.sum(axis=1, keepdims=True)

